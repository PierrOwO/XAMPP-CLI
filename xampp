#!/bin/bash

VERSION="1.4.0"

CONFIG_DIR="$HOME/.xampp-cli"
CONFIG_FILE="$CONFIG_DIR/config"

GREEN="\033[32m"
RED="\033[31m"
YELLOW="\033[33m"
CYAN="\033[36m"
BOLD="\033[1m"
RESET="\033[0m"


ok(){
    echo -e "${GREEN}✓${RESET} $1"
}

fail(){
    echo -e "${RED}✗${RESET} $1"
}

warn(){
    echo -e "${YELLOW}!${RESET} $1"
}


detect_xampp(){

    PATHS=(
        "/Applications/XAMPP/xamppfiles/xampp"
        "/Applications/xampp/xamppfiles/xampp"
        "/opt/lampp/lampp"
    )


    for path in "${PATHS[@]}"
    do
        if [ -f "$path" ]; then
            echo "$path"
            return
        fi
    done
}



create_config(){

    mkdir -p "$CONFIG_DIR"

    XAMPP_FOUND=$(detect_xampp)

    if [ -z "$XAMPP_FOUND" ]; then
        return 1
    fi


    cat > "$CONFIG_FILE" <<EOF
XAMPP_PATH=$XAMPP_FOUND
MYSQL_PORT=3306
APACHE_PORT=80
PHPMYADMIN_URL=http://localhost/phpmyadmin
EOF

}



setup(){

    echo ""
    echo -e "${BOLD}XAMPP Setup${RESET}"
    echo "-----------"
    echo ""

    echo "Searching for XAMPP..."
    echo ""


    FOUND=$(detect_xampp)


    if [ -n "$FOUND" ]; then

        ok "Found:"
        echo "  $FOUND"
        echo ""

        read -p "Use this installation? [Y/n]: " answer


        if [[ "$answer" =~ ^[Nn]$ ]]; then

            read -p "Enter XAMPP path: " FOUND

        fi

    else

        warn "Automatic detection failed"
        read -p "Enter XAMPP path: " FOUND

    fi



    if [ -f "$FOUND" ]; then

        mkdir -p "$CONFIG_DIR"


        cat > "$CONFIG_FILE" <<EOF
XAMPP_PATH=$FOUND
MYSQL_PORT=3306
APACHE_PORT=80
PHPMYADMIN_URL=http://localhost/phpmyadmin
EOF


        echo ""
        ok "Configuration saved"
        echo ""

    else

        fail "Invalid XAMPP path"

    fi

}



if [ ! -f "$CONFIG_FILE" ]; then
    create_config >/dev/null 2>&1
fi



if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi



XAMPP="${XAMPP_PATH:-$(detect_xampp)}"

XAMPP_DIR="$(dirname "$(dirname "$XAMPP")")"

MYSQLADMIN="$XAMPP_DIR/bin/mysqladmin"
MYSQLD="$XAMPP_DIR/sbin/mysqld"
HTTPD="$XAMPP_DIR/bin/httpd"



mysql_running(){

    "$MYSQLADMIN" ping \
    -u root \
    --socket="$XAMPP_DIR/var/mysql/mysql.sock" \
    >/dev/null 2>&1

}



apache_running(){

    pgrep -f "$HTTPD" >/dev/null

}



start_mysql(){

    if mysql_running
    then
        echo "MySQL already running"
    else
        sudo "$XAMPP" startmysql
    fi

}



stop_mysql(){

    if mysql_running
    then
        sudo "$XAMPP" stopmysql
    else
        echo "MySQL already stopped"
    fi

}



start_apache(){

    if apache_running
    then
        echo "Apache already running"
    else
        sudo "$XAMPP" startapache
    fi

}



stop_apache(){

    if apache_running
    then
        sudo "$XAMPP" stopapache
    else
        echo "Apache already stopped"
    fi

}



status(){

    echo ""
    echo -e "${BOLD}XAMPP Status${RESET}"
    echo "------------"


    if mysql_running
    then
        echo -e "MySQL:  ${GREEN}running${RESET}"
    else
        echo -e "MySQL:  ${RED}stopped${RESET}"
    fi


    if apache_running
    then
        echo -e "Apache: ${GREEN}running${RESET}"
    else
        echo -e "Apache: ${RED}stopped${RESET}"
    fi


    echo ""

}



doctor(){

    echo ""
    echo -e "${BOLD}XAMPP Doctor${RESET}"
    echo "------------"
    echo ""


    if [ -f "$XAMPP" ]
    then
        ok "XAMPP detected"
    else
        fail "XAMPP not found"
    fi


    if [ -f "$MYSQLD" ]
    then
        ok "MySQL detected"
    else
        fail "MySQL missing"
    fi


    if [ -f "$HTTPD" ]
    then
        ok "Apache detected"
    else
        fail "Apache missing"
    fi


    echo ""

    echo "Configuration:"
    echo ""

    echo "XAMPP:"
    echo "$XAMPP"

    echo ""

}



show_config(){

    echo ""
    echo -e "${BOLD}XAMPP CLI Config${RESET}"
    echo "----------------"

    cat "$CONFIG_FILE"

    echo ""

}



info(){

    echo ""
    echo -e "${BOLD}XAMPP CLI Info${RESET}"
    echo "--------------"
    echo ""

    echo "Version:"
    echo "$VERSION"

    echo ""

    echo "XAMPP:"
    echo "$XAMPP"

    echo ""

    if [ -f "$XAMPP" ]; then

        VERSION_OUTPUT=$(sudo "$XAMPP" --version 2>/dev/null)

        echo "XAMPP Version:"
        echo "$VERSION_OUTPUT"

    fi


    echo ""

    echo "Services:"
    status

}



open_phpmyadmin(){

    open "$PHPMYADMIN_URL"

}



help(){

    echo ""
    echo "XAMPP CLI v$VERSION"
    echo ""

    echo "Commands:"
    echo ""

    echo " xampp start"
    echo " xampp stop"
    echo " xampp restart"
    echo ""

    echo " xampp mysql start"
    echo " xampp mysql stop"
    echo ""

    echo " xampp apache start"
    echo " xampp apache stop"
    echo ""

    echo " xampp status"
    echo " xampp doctor"
    echo " xampp config"
    echo " xampp setup"
    echo " xampp info"
    echo ""

    echo " xampp open phpmyadmin"

    echo ""

}



case "$1:$2" in


start:)
    start_mysql
    start_apache
;;


stop:)
    stop_apache
    stop_mysql
;;


restart:)
    stop_apache
    stop_mysql

    sleep 2

    start_mysql
    start_apache
;;


mysql:start)
    start_mysql
;;


mysql:stop)
    stop_mysql
;;


apache:start)
    start_apache
;;


apache:stop)
    stop_apache
;;


status:)
    status
;;


doctor:)
    doctor
;;


config:)
    show_config
;;


setup:)
    setup
;;


info:)
    info
;;


open:phpmyadmin)
    open_phpmyadmin
;;


help:)
    help
;;


*)
    help
;;


esac