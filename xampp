#!/bin/bash

VERSION="1.4.1"

CONFIG_DIR="$HOME/.xampp-cli"
CONFIG_FILE="$CONFIG_DIR/config"


GREEN="\033[32m"
RED="\033[31m"
YELLOW="\033[33m"
CYAN="\033[36m"
BOLD="\033[1m"
RESET="\033[0m"



spinner(){

    local pid=$1
    local message=$2

    local frames=("⠋" "⠙" "⠸" "⠴" "⠦" "⠇")
    local i=0


    while kill -0 "$pid" 2>/dev/null; do

        printf "\r%s %s" "$message" "${frames[$i]}"

        i=$(( (i+1) % 6 ))

        sleep 0.1

    done


    printf "\r%s ${GREEN}✓${RESET}\n" "$message"

}



run(){

    local message="$1"
    shift


    sudo -v


    "$@" >/tmp/xampp-cli.log 2>&1 &

    local pid=$!


    spinner "$pid" "$message"


    wait "$pid"


    if [ $? -ne 0 ]; then

        echo -e "${RED}✗ Failed${RESET}"

        cat /tmp/xampp-cli.log

        return 1

    fi

}



detect_xampp(){

    PATHS=(

        "/Applications/XAMPP/xamppfiles/xampp"
        "/Applications/xampp/xamppfiles/xampp"
        "/opt/lampp/lampp"

    )


    for path in "${PATHS[@]}"
    do

        if [ -f "$path" ]; then

            echo "$path"
            return

        fi

    done

}



create_config(){

    mkdir -p "$CONFIG_DIR"


    FOUND=$(detect_xampp)


    if [ -z "$FOUND" ]; then
        return
    fi


cat > "$CONFIG_FILE" <<EOF
XAMPP_PATH=$FOUND
MYSQL_PORT=3306
APACHE_PORT=80
PHPMYADMIN_URL=http://localhost/phpmyadmin
EOF

}



setup(){

    echo ""
    echo -e "${BOLD}XAMPP Setup${RESET}"
    echo "-----------"
    echo ""


    FOUND=$(detect_xampp)


    if [ -n "$FOUND" ]; then

        echo "Found:"
        echo "$FOUND"
        echo ""

        read -p "Use this installation? [Y/n]: " answer


        if [[ "$answer" =~ ^[Nn]$ ]]; then
            read -p "XAMPP path: " FOUND
        fi

    else

        read -p "XAMPP path: " FOUND

    fi



    mkdir -p "$CONFIG_DIR"


cat > "$CONFIG_FILE" <<EOF
XAMPP_PATH=$FOUND
MYSQL_PORT=3306
APACHE_PORT=80
PHPMYADMIN_URL=http://localhost/phpmyadmin
EOF


    echo ""
    echo -e "${GREEN}✓${RESET} Configuration saved"
    echo ""

}



if [ ! -f "$CONFIG_FILE" ]; then

    create_config

fi



if [ -f "$CONFIG_FILE" ]; then

    source "$CONFIG_FILE"

fi



XAMPP="${XAMPP_PATH:-$(detect_xampp)}"


# IMPORTANT:
# /Applications/XAMPP/xamppfiles/xampp
# dirname -> /Applications/XAMPP/xamppfiles

XAMPP_DIR="$(dirname "$XAMPP")"


MYSQLD="$XAMPP_DIR/sbin/mysqld"
HTTPD="$XAMPP_DIR/bin/httpd"

MYSQLADMIN="$XAMPP_DIR/bin/mysqladmin"



mysql_running(){

    if sudo "$XAMPP" status 2>/dev/null | grep -qi "MySQL is running"; then
        return 0
    fi


    if pgrep -f "$MYSQLD" >/dev/null; then
        return 0
    fi


    return 1

}



apache_running(){

    if sudo "$XAMPP" status 2>/dev/null | grep -qi "Apache is running"; then
        return 0
    fi


    if pgrep -f "$HTTPD" >/dev/null; then
        return 0
    fi


    return 1

}



start_mysql(){

    if mysql_running; then

        echo -e "MySQL: ${YELLOW}already running${RESET}"

    else

        run "Starting MySQL..." sudo "$XAMPP" startmysql

    fi

}



stop_mysql(){

    if mysql_running; then


        run "Stopping MySQL..." sudo "$XAMPP" stopmysql


        sleep 2


        PIDS=$(pgrep -f "$MYSQLD")


        if [ -n "$PIDS" ]; then


            echo -e "${YELLOW}XAMPP did not stop MySQL, forcing shutdown...${RESET}"


            for PID in $PIDS
            do

                echo "Force stopping MySQL process: $PID"

                sudo kill -9 "$PID"

            done


            sleep 2

        fi



        if pgrep -f "$MYSQLD" >/dev/null; then

            echo -e "${RED}MySQL still running${RESET}"

        else

            echo -e "MySQL: ${GREEN}stopped${RESET}"

        fi


    else

        echo -e "MySQL: ${YELLOW}already stopped${RESET}"

    fi

}



start_apache(){

    if apache_running; then

        echo -e "Apache: ${YELLOW}already running${RESET}"

    else

        run "Starting Apache..." sudo "$XAMPP" startapache

    fi

}



stop_apache(){

    if apache_running; then

        run "Stopping Apache..." sudo "$XAMPP" stopapache

        echo -e "Apache: ${GREEN}stopped${RESET}"

    else

        echo -e "Apache: ${YELLOW}already stopped${RESET}"

    fi

}



status(){

    echo ""

    echo -e "${BOLD}XAMPP Status${RESET}"
    echo "------------"


    if mysql_running; then
        echo -e "MySQL:  ${GREEN}running${RESET}"
    else
        echo -e "MySQL:  ${RED}stopped${RESET}"
    fi



    if apache_running; then
        echo -e "Apache: ${GREEN}running${RESET}"
    else
        echo -e "Apache: ${RED}stopped${RESET}"
    fi


    echo ""

}



start_all(){

    echo ""
    echo -e "${CYAN}Starting XAMPP...${RESET}"
    echo ""


    start_mysql
    start_apache


    echo ""
    echo -e "${GREEN}XAMPP is ready.${RESET}"
    echo ""

}



stop_all(){

    echo ""
    echo -e "${CYAN}Stopping XAMPP...${RESET}"
    echo ""


    stop_apache
    stop_mysql


    echo ""
    echo -e "${GREEN}XAMPP stopped.${RESET}"
    echo ""

}



doctor(){

    echo ""
    echo -e "${BOLD}XAMPP Doctor${RESET}"
    echo "------------"
    echo ""


    if [ -f "$XAMPP" ]; then
        echo -e "${GREEN}✓${RESET} XAMPP detected"
    else
        echo -e "${RED}✗${RESET} XAMPP missing"
    fi



    if [ -f "$MYSQLD" ]; then
        echo -e "${GREEN}✓${RESET} MySQL detected"
    else
        echo -e "${RED}✗${RESET} MySQL missing"
    fi



    if [ -f "$HTTPD" ]; then
        echo -e "${GREEN}✓${RESET} Apache detected"
    else
        echo -e "${RED}✗${RESET} Apache missing"
    fi


    echo ""

}



show_config(){

    echo ""
    echo -e "${BOLD}XAMPP CLI Config${RESET}"
    echo "----------------"

    cat "$CONFIG_FILE"

    echo ""

}



info(){

    echo ""
    echo -e "${BOLD}XAMPP CLI Info${RESET}"
    echo "--------------"
    echo ""

    echo "Version:"
    echo "$VERSION"

    echo ""

    echo "XAMPP:"
    echo "$XAMPP"

    echo ""

    status

}



open_phpmyadmin(){

    open "$PHPMYADMIN_URL"

}



help(){

    echo ""
    echo "XAMPP CLI v$VERSION"
    echo ""

    echo "Commands:"
    echo ""

    echo " xampp start"
    echo " xampp stop"
    echo " xampp restart"
    echo ""

    echo " xampp mysql start"
    echo " xampp mysql stop"
    echo ""

    echo " xampp apache start"
    echo " xampp apache stop"
    echo ""

    echo " xampp status"
    echo " xampp doctor"
    echo " xampp config"
    echo " xampp setup"
    echo " xampp info"
    echo ""

    echo " xampp open phpmyadmin"
    echo ""

}



case "$1:$2" in

start:)
    start_all
;;

stop:)
    stop_all
;;

restart:)
    stop_all
    sleep 2
    start_all
;;

mysql:start)
    start_mysql
;;

mysql:stop)
    stop_mysql
;;

apache:start)
    start_apache
;;

apache:stop)
    stop_apache
;;

status:)
    status
;;

doctor:)
    doctor
;;

config:)
    show_config
;;

setup:)
    setup
;;

info:)
    info
;;

open:phpmyadmin)
    open_phpmyadmin
;;

help:)
    help
;;

*)
    help
;;

esac