#!/bin/bash

VERSION="1.2.0"

XAMPP="/Applications/XAMPP/xamppfiles/xampp"
MYSQLADMIN="/Applications/XAMPP/xamppfiles/bin/mysqladmin"
MYSQLD="/Applications/XAMPP/xamppfiles/sbin/mysqld"
HTTPD="/Applications/XAMPP/xamppfiles/bin/httpd"

PHPMYADMIN_URL="http://localhost/phpmyadmin"


GREEN="\033[32m"
RED="\033[31m"
YELLOW="\033[33m"
CYAN="\033[36m"
BOLD="\033[1m"
RESET="\033[0m"


ok() {
    echo -e "${GREEN}✓${RESET} $1"
}

fail() {
    echo -e "${RED}✗${RESET} $1"
}

warn() {
    echo -e "${YELLOW}!${RESET} $1"
}


spinner() {

    local pid=$1
    local message=$2

    local frames=("⠋" "⠙" "⠸" "⠴" "⠦" "⠇")
    local i=0

    while kill -0 "$pid" 2>/dev/null; do

        printf "\r%s %s" "$message" "${frames[$i]}"

        i=$(( (i+1) % 6 ))

        sleep 0.1

    done

    printf "\r%s ${GREEN}✓${RESET}\n" "$message"
}



run() {

    local message="$1"
    shift

    sudo -v

    "$@" >/tmp/xampp-cli.log 2>&1 &

    local pid=$!

    spinner "$pid" "$message"

    wait "$pid"

}



mysql_running() {

    "$MYSQLADMIN" ping \
    -u root \
    --socket="/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock" \
    >/dev/null 2>&1

}



apache_running() {

    pgrep -f "$HTTPD" >/dev/null

}



port_used() {

    lsof -i :"$1" >/dev/null 2>&1

}



start_mysql() {

    if mysql_running; then

        echo "MySQL: already running"

    else

        run "Starting MySQL..." sudo "$XAMPP" startmysql

    fi

}



stop_mysql() {

    if mysql_running; then

        run "Stopping MySQL..." sudo "$XAMPP" stopmysql

    else

        echo "MySQL: already stopped"

    fi

}



start_apache() {

    if apache_running; then

        echo "Apache: already running"

    else

        run "Starting Apache..." sudo "$XAMPP" startapache

    fi

}



stop_apache() {

    if apache_running; then

        run "Stopping Apache..." sudo "$XAMPP" stopapache

    else

        echo "Apache: already stopped"

    fi

}



status() {

    echo ""
    echo -e "${BOLD}XAMPP Status${RESET}"
    echo "------------"


    if mysql_running; then
        echo -e "MySQL:      ${GREEN}running${RESET}"
    else
        echo -e "MySQL:      ${RED}stopped${RESET}"
    fi


    if apache_running; then
        echo -e "Apache:     ${GREEN}running${RESET}"
    else
        echo -e "Apache:     ${RED}stopped${RESET}"
    fi


    if port_used 80; then
        echo -e "HTTP:       ${GREEN}80 open${RESET}"
    else
        echo -e "HTTP:       ${RED}80 closed${RESET}"
    fi


    if port_used 3306; then
        echo -e "MySQL Port: ${GREEN}3306 open${RESET}"
    else
        echo -e "MySQL Port: ${RED}3306 closed${RESET}"
    fi


    echo ""

}



ports() {

    echo ""
    echo -e "${BOLD}XAMPP Ports${RESET}"
    echo "------------"

    echo ""

    echo "Apache:"
    lsof -i :80 | tail -n +2 || echo "No process"


    echo ""

    echo "MySQL:"
    lsof -i :3306 | tail -n +2 || echo "No process"


    echo ""

}



doctor() {

    echo ""
    echo -e "${BOLD}XAMPP Doctor${RESET}"
    echo "------------"
    echo ""


    if [ -d "/Applications/XAMPP" ]; then
        ok "XAMPP installation found"
    else
        fail "XAMPP installation missing"
    fi


    if [ -f "$XAMPP" ]; then
        ok "XAMPP controller found"
    else
        fail "XAMPP controller missing"
    fi


    if [ -f "$MYSQLD" ]; then
        ok "MySQL binary found"
    else
        fail "MySQL binary missing"
    fi


    if [ -f "$HTTPD" ]; then
        ok "Apache binary found"
    else
        fail "Apache binary missing"
    fi



    echo ""

    echo "Checking ports..."


    if port_used 80; then
        ok "Port 80 available"
    else
        warn "Port 80 not active"
    fi


    if port_used 3306; then
        ok "Port 3306 active"
    else
        warn "Port 3306 not active"
    fi



    echo ""

    if mysql_running; then
        ok "MySQL connection successful"
    else
        warn "MySQL not running"
    fi



    if apache_running; then
        ok "Apache process detected"
    else
        warn "Apache not running"
    fi


    echo ""

}



open_phpmyadmin() {

    echo "Opening phpMyAdmin..."

    open "$PHPMYADMIN_URL"

}



case "$1:$2" in


start:)
    start_mysql
    start_apache
;;


stop:)
    stop_apache
    stop_mysql
;;


restart:)
    stop_apache
    stop_mysql
    sleep 2
    start_mysql
    start_apache
;;


mysql:start)
    start_mysql
;;


mysql:stop)
    stop_mysql
;;


apache:start)
    start_apache
;;


apache:stop)
    stop_apache
;;


status:)
    status
;;


ports:)
    ports
;;


doctor:)
    doctor
;;


open:phpmyadmin)
    open_phpmyadmin
;;


help:)
    echo ""
    echo "XAMPP CLI v$VERSION"
    echo ""
    echo "Commands:"
    echo ""
    echo "  xampp start"
    echo "  xampp stop"
    echo "  xampp restart"
    echo ""
    echo "  xampp mysql start"
    echo "  xampp mysql stop"
    echo ""
    echo "  xampp apache start"
    echo "  xampp apache stop"
    echo ""
    echo "  xampp status"
    echo "  xampp ports"
    echo "  xampp doctor"
    echo "  xampp open phpmyadmin"
    echo ""

;;


*)
    echo "Unknown command. Use: xampp help"
;;


esac